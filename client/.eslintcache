js",[],["61","62"],"/mnt/d/web_dev/Learn_About_me/client/src/app.js",["63","64"],"import React, { useState } from 'react';\r\nimport {StateProvider} from './GlobalState'\r\nimport { BrowserRouter } from \"react-router-dom\";\r\nimport Header from './components/header/header';\r\nimport MainPages from './components/mainpages/pages';\r\nimport styled from 'styled-components';\r\n\r\nconst App = () => {\r\n    return (\r\n        <StateProvider>\r\n            <BrowserRouter>\r\n                <Header />\r\n            <MainPages/>\r\n            </BrowserRouter>\r\n        </StateProvider>\r\n    );\r\n};\r\n\r\nexport default App;\r\n","/mnt/d/web_dev/Learn_About_me/client/src/GlobalState.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/header/header.js",["65"],"import React, { useContext } from 'react';\r\nimport './header.css';\r\nimport { Link } from 'react-router-dom';\r\nimport { GlobalState } from '../../GlobalState';\r\nimport ImageHolder from '../util/ImageHolder/ImageHoder';\r\nimport styled from 'styled-components';\r\n\r\nconst Nav = styled.header`\r\n    position:relative;\r\n    background-color: #581b98;\r\n    display: flex;\r\n    flex-direction: row;\r\n    width: 100%;\r\n    height: 5rem;\r\n    justify-content: flex-end;\r\n    align-items: center;\r\n    z-index:100;\r\n    box-shadow:0px 5px 20px 1px rgba(0,0,0,0.4) ;\r\n\r\n`;\r\nconst NavItem = styled.div`\r\n    font-size: 1.5rem;\r\n    margin: 0.5rem;\r\n    a {\r\n        text-decoration: none;\r\n        color: #faee1c;\r\n    }\r\n    ${(props) => (props.start ? 'margin-right:auto' : '')}\r\n`;\r\n\r\nconst toggleLogoutIn = (isLogged) => {\r\n    return isLogged ? (\r\n        <NavItem>\r\n            <Link to=\"/logout\">logout</Link>\r\n        </NavItem>\r\n    ) : (\r\n        <>\r\n            <NavItem>\r\n                <Link to=\"/login\">login</Link>\r\n            </NavItem>\r\n            <NavItem>\r\n                <Link to=\"/signup\">signup</Link>\r\n            </NavItem>\r\n        </>\r\n    );\r\n};\r\n\r\nexport default function Header() {\r\n    const { user, setUser } = useContext(GlobalState);\r\n    console.log(user.imgUrl);\r\n    return (\r\n        <Nav>\r\n            <NavItem start>\r\n                <Link to=\"/\">Home</Link>\r\n            </NavItem>\r\n            {toggleLogoutIn(user.isLogged)}\r\n            <NavItem>\r\n                {user.isLogged && <ImageHolder imgUrl={user.imgUrl} />}\r\n            </NavItem>\r\n        </Nav>\r\n    );\r\n}\r\n","/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/pages.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/home/Home.js",["66"],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/signup/signup.js",["67"],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/login/login.js",["68"],"/mnt/d/web_dev/Learn_About_me/client/src/GlobalStyle.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/logout/logout.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/card/Card.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/signup/signupStyle.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/login/loginStyle.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/util/ImageHolder/ImageHoder.js",[],{"ruleId":"69","replacedBy":"70"},{"ruleId":"71","replacedBy":"72"},{"ruleId":"73","severity":1,"message":"74","line":1,"column":17,"nodeType":"75","messageId":"76","endLine":1,"endColumn":25},{"ruleId":"73","severity":1,"message":"77","line":6,"column":8,"nodeType":"75","messageId":"76","endLine":6,"endColumn":14},{"ruleId":"73","severity":1,"message":"78","line":49,"column":19,"nodeType":"75","messageId":"76","endLine":49,"endColumn":26},{"ruleId":"73","severity":1,"message":"79","line":7,"column":19,"nodeType":"75","messageId":"76","endLine":7,"endColumn":27},{"ruleId":"73","severity":1,"message":"80","line":1,"column":8,"nodeType":"75","messageId":"76","endLine":1,"endColumn":13},{"ruleId":"73","severity":1,"message":"80","line":1,"column":8,"nodeType":"75","messageId":"76","endLine":1,"endColumn":13},"no-native-reassign",["81"],"no-negated-in-lhs",["82"],"no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar","'styled' is defined but never used.","'setUser' is assigned a value but never used.","'setUsers' is assigned a value but never used.","'axios' is defined but never used.","no-global-assign","no-unsafe-negation"]
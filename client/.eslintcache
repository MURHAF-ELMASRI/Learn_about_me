   </BrowserRouter>\r\n        </StateProvider>\r\n    );\r\n};\r\n\r\nexport default App;\r\n","/mnt/d/web_dev/Learn_About_me/client/src/GlobalState.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/header/header.js",["58"],"import React, { useContext } from 'react';\r\nimport './header.css';\r\nimport { Link } from 'react-router-dom';\r\nimport { GlobalState } from '../../GlobalState';\r\nimport ImageHolder from '../util/ImageHolder/ImageHolder.js';\r\nimport styled from 'styled-components';\r\n\r\nconst Nav = styled.header`\r\n    background-color: #581b98;\r\n    display: flex;\r\n    flex-direction: row;\r\n    width: 100%;\r\n    height: 5rem;\r\n    justify-content: flex-end;\r\n    align-items: center;\r\n    box-shadow:0px 5px 20px 1px rgba(0,0,0,0.4) ;\r\n\r\n`;\r\nconst NavItem = styled.div`\r\n    font-size: 1.5rem;\r\n    margin: 0.5rem;\r\n    a {\r\n        text-decoration: none;\r\n        color: #faee1c;\r\n    }\r\n    ${(props) => (props.start ? 'margin-right:auto' : '')}\r\n`;\r\n\r\nconst toggleLogoutIn = (isLogged) => {\r\n    return isLogged ? (\r\n        <NavItem>\r\n            <Link to=\"/logout\">logout</Link>\r\n        </NavItem>\r\n    ) : (\r\n        <>\r\n            <NavItem>\r\n                <Link to=\"/login\">login</Link>\r\n            </NavItem>\r\n            <NavItem>\r\n                <Link to=\"/signup\">signpu</Link>\r\n            </NavItem>\r\n        </>\r\n    );\r\n};\r\n\r\nexport default function Header() {\r\n    const { user, setUser } = useContext(GlobalState);\r\n    console.log(user.imgUrl);\r\n    return (\r\n        <Nav>\r\n            <NavItem start>\r\n                <Link to=\"/\">Home</Link>\r\n            </NavItem>\r\n            {toggleLogoutIn(user.isLogged)}\r\n            <NavItem>\r\n                <ImageHolder imgUrl={user.imgUrl} />\r\n            </NavItem>\r\n        </Nav>\r\n    );\r\n}\r\n","/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/pages.js",[],"/mnt/d/w
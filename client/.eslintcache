>\r\n            <MainPages/>\r\n            </BrowserRouter>\r\n        </StateProvider>\r\n    );\r\n};\r\n\r\nexport default App;\r\n","/mnt/d/web_dev/Learn_About_me/client/src/GlobalState.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/header/header.js",["59"],"import React, { useContext } from 'react';\r\nimport './header.css';\r\nimport { Link } from 'react-router-dom';\r\nimport { GlobalState } from '../../GlobalState';\r\nimport ImageHolder from '../util/ImageHolder/ImageHolder.js';\r\nimport styled from 'styled-components';\r\n\r\nconst Nav = styled.header`\r\n    background-color: #581b98;\r\n    display: flex;\r\n    flex-direction: row;\r\n    width: 100%;\r\n    height: 5rem;\r\n    justify-content: flex-end;\r\n    align-items: center;\r\n    box-shadow:0px 5px 20px 1px rgba(0,0,0,0.4) ;\r\n\r\n`;\r\nconst NavItem = styled.div`\r\n    font-size: 1.5rem;\r\n    margin: 0.5rem;\r\n    a {\r\n        text-decoration: none;\r\n        color: #faee1c;\r\n    }\r\n    ${(props) => (props.start ? 'margin-right:auto' : '')}\r\n`;\r\n\r\nconst toggleLogoutIn = (isLogged) => {\r\n    return isLogged ? (\r\n        <NavItem>\r\n            <Link to=\"/logout\">logout</Link>\r\n        </NavItem>\r\n    ) : (\r\n        <>\r\n            <NavItem>\r\n                <Link to=\"/login\">login</Link>\r\n            </NavItem>\r\n            <NavItem>\r\n                <Link to=\"/signup\">signup</Link>\r\n            </NavItem>\r\n        </>\r\n    );\r\n};\r\n\r\nexport default function Header() {\r\n    const { user, setUser } = useContext(GlobalState);\r\n    console.log(user.imgUrl);\r\n    return (\r\n        <Nav>\r\n            <NavItem start>\r\n                <Link to=\"/\">Home</Link>\r\n            </NavItem>\r\n            {toggleLogoutIn(user.isLogged)}\r\n            <NavItem>\r\n                {user.isLogged && <ImageHolder imgUrl={user.imgUrl} />}\r\n            </NavItem>\r\n        </Nav>\r\n    );\r\n}\r\n","/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/pages.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/home/Home.js",["60"],"import { useEffect, useState } from 'react';\r\nimport Card from '../card/Card';\r\nimport axios from 'axios';\r\nimport styled from 'styled-components';\r\n\r\nconst Home = () => {\r\n    const [users, setUsers] = useState([]);\r\n\r\n    useEffect(() => {\r\n        axios\r\n            .get('/')\r\n            .then((res) => {\r\n                console.log(res.body);\r\n            })\r\n            .catch((err) => console.log(err));\r\n    }, []);\r\n\r\n    const CardContainer = styled.div``;\r\n\r\n    function showUser(users) {\r\n        return users.map((e) => <Card info={e} />);\r\n    }\r\n\r\n    return <CardContainer>{showUser(users)}</CardContainer>;\r\n};\r\n\r\nexport default Home;\r\n","/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/signup/signup.js",["61","62","63","64","65"],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/login/login.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/util/ImageHolder/ImageHolder.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/GlobalStyle.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/logout/logout.js",[],"/mnt/d/web_dev/Learn_About_me/client/src/components/mainpages/card/Card.js",[],["66","67"],{"ruleId":"68","replacedBy":"69"},{"ruleId":"70","replacedBy":"71"},{"ruleId":"72","severity":1,"message":"73","line":1,"column":17,"nodeType":"74","messageId":"75","endLine":1,"endColumn":25},{"ruleId":"72","severity":1,"message":"76","line":6,"column":8,"nodeType":"74","messageId":"75","endLine":6,"endColumn":14},{"ruleId":"72","severity":1,"message":"77","line":47,"column":19,"nodeType":"74","messageId":"75","endLine":47,"endColumn":26},{"ruleId":"72","severity":1,"message":"78","line":7,"column":19,"nodeType":"74","messageId":"75","endLine":7,"endColumn":27},{"ruleId":"72","severity":1,"message":"79","line":1,"column":8,"n